      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var responseBody = pm.response.json();\r",
              "pm.environment.set(\"student_id\",responseBody.id);\r",
              "\r",
              "pm.test(\"Status code should be 200\",function(){\r",
              "    pm.response.to.have.status(200);\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
